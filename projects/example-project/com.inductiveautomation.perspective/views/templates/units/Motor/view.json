{
  "custom": {},
  "params": {
    "displayName": "",
    "tagPath": "[example-tags]Overview/Motor 8"
  },
  "propConfig": {
    "params.displayName": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 180,
      "width": 280
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "Dot"
                },
                "position": {
                  "basis": "11px",
                  "shrink": 0
                },
                "propConfig": {
                  "props.fill.paint": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.tagPath} + \u0027/HOA\u0027) \u003d 2, \u0027#1f7a7a\u0027, if(tag({view.params.tagPath} + \u0027/HOA\u0027) \u003d 1, \u0027#d49a1f\u0027, if(tag({view.params.tagPath} + \u0027/HOA\u0027) \u003d 0, \u0027#4a4a47\u0027, \u0027#cccccc\u0027)))"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "fill": {},
                  "stroke": {
                    "paint": "#111111",
                    "width": 0.5
                  }
                },
                "type": "ia.shapes.ellipse"
              },
              {
                "meta": {
                  "name": "Id"
                },
                "position": {
                  "grow": 1
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "path": "view.params.displayName"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "style": {
                    "color": "#111111",
                    "fontFamily": "\u0027IBM Plex Mono\u0027, monospace",
                    "fontSize": "12px",
                    "fontWeight": 700,
                    "letterSpacing": "2px"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "Hdr"
            },
            "position": {
              "basis": "20px",
              "shrink": 0
            },
            "props": {
              "alignItems": "center",
              "style": {
                "gap": "8px"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "HOA"
                },
                "position": {
                  "basis": "150px",
                  "shrink": 0
                },
                "propConfig": {
                  "props.controlValue": {
                    "binding": {
                      "config": {
                        "expression": "tag({view.params.tagPath} + \u0027/HOA\u0027)"
                      },
                      "type": "expr"
                    }
                  },
                  "props.indicatorValue": {
                    "binding": {
                      "config": {
                        "expression": "tag({view.params.tagPath} + \u0027/HOA\u0027)"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "orientation": "row",
                  "states": [
                    {
                      "selectedStyle": {
                        "backgroundColor": "#4a4a47",
                        "border": "0",
                        "borderRadius": "0",
                        "classes": "",
                        "color": "#ffffff",
                        "fontFamily": "\u0027IBM Plex Mono\u0027, monospace",
                        "fontSize": "10px",
                        "fontWeight": 700,
                        "letterSpacing": "1px"
                      },
                      "text": "OFF",
                      "unselectedStyle": {
                        "backgroundColor": "#a3a3a0",
                        "border": "1px solid #6e6e6c",
                        "borderRadius": "0",
                        "classes": "",
                        "color": "#5f5f5c",
                        "fontFamily": "\u0027IBM Plex Mono\u0027, monospace",
                        "fontSize": "10px",
                        "letterSpacing": "1px"
                      },
                      "value": 0
                    },
                    {
                      "selectedStyle": {
                        "backgroundColor": "#d49a1f",
                        "border": "0",
                        "borderRadius": "0",
                        "color": "#1a1a18",
                        "fontFamily": "\u0027IBM Plex Mono\u0027, monospace",
                        "fontSize": "10px",
                        "fontWeight": 700,
                        "letterSpacing": "1px"
                      },
                      "text": "HAND",
                      "unselectedStyle": {
                        "backgroundColor": "#a3a3a0",
                        "border": "1px solid #6e6e6c",
                        "borderRadius": "0",
                        "color": "#5f5f5c",
                        "fontFamily": "\u0027IBM Plex Mono\u0027, monospace",
                        "fontSize": "10px",
                        "letterSpacing": "1px"
                      },
                      "value": 1
                    },
                    {
                      "selectedStyle": {
                        "backgroundColor": "#1f7a7a",
                        "border": "0",
                        "borderRadius": "0",
                        "color": "#ffffff",
                        "fontFamily": "\u0027IBM Plex Mono\u0027, monospace",
                        "fontSize": "10px",
                        "fontWeight": 700,
                        "letterSpacing": "1px"
                      },
                      "text": "AUTO",
                      "unselectedStyle": {
                        "backgroundColor": "#a3a3a0",
                        "border": "1px solid #6e6e6c",
                        "borderRadius": "0",
                        "color": "#5f5f5c",
                        "fontFamily": "\u0027IBM Plex Mono\u0027, monospace",
                        "fontSize": "10px",
                        "letterSpacing": "1px"
                      },
                      "value": 2
                    }
                  ]
                },
                "type": "ia.input.multi-state-button"
              }
            ],
            "meta": {
              "name": "HOARow"
            },
            "position": {
              "basis": "30px",
              "shrink": 0
            },
            "props": {
              "style": {
                "justifyContent": "flex-start"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "Amps"
                },
                "position": {
                  "grow": 1
                },
                "propConfig": {
                  "props.style.color": {
                    "binding": {
                      "config": {
                        "expression": "if((tag({view.params.tagPath} + \u0027/Amps\u0027)) \u003e\u003d 160, \u0027#c8362a\u0027, if((tag({view.params.tagPath} + \u0027/Amps\u0027)) \u003e\u003d 130, \u0027#d49a1f\u0027, \u0027#111111\u0027))"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "numberFormat(tag({view.params.tagPath} + \u0027/Amps\u0027), \u00270.0\u0027)"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "fontFamily": "\u0027IBM Plex Mono\u0027, monospace",
                    "fontSize": "22px",
                    "fontWeight": 700,
                    "lineHeight": "1.0"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "U"
                },
                "props": {
                  "style": {
                    "alignSelf": "flex-end",
                    "color": "#5f5f5c",
                    "fontFamily": "\u0027IBM Plex Mono\u0027, monospace",
                    "fontSize": "11px",
                    "marginLeft": "4px"
                  },
                  "text": "A"
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "AmpsRow"
            },
            "position": {
              "basis": "28px"
            },
            "props": {
              "alignItems": "baseline"
            },
            "type": "ia.container.flex"
          },
          {
            "meta": {
              "name": "MAI"
            },
            "position": {
              "basis": "50px"
            },
            "propConfig": {
              "props.processValue": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.tagPath} + \u0027/Amps\u0027)"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "desiredHigh": 105,
              "desiredLow": 80,
              "highAlarm": 105,
              "highHighAlarm": 110,
              "highInterlock": null,
              "lowAlarm": 80,
              "lowInterlock": null,
              "lowLowAlarm": 70,
              "maxValue": 120,
              "minValue": 50
            },
            "type": "ia.display.moving-analog-indicator"
          },
          {
            "meta": {
              "name": "Sub"
            },
            "position": {
              "basis": "14px"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "replace({view.params.displayName}, \u0027M-\u0027, \u0027CONV-\u0027)"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "#5f5f5c",
                "fontFamily": "\u0027IBM Plex Mono\u0027, monospace",
                "fontSize": "9px",
                "letterSpacing": "1px"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "Card"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "backgroundColor": "#c9c9c6",
            "gap": "6px",
            "padding": "10px 12px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "backgroundColor": "#c9c9c6",
        "gap": "0px",
        "overflow": "hidden",
        "padding": "0"
      }
    },
    "type": "ia.container.flex"
  }
}