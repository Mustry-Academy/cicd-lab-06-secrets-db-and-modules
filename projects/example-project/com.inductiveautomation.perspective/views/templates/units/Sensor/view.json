{
  "custom": {
    "data": {}
  },
  "params": {
    "displayName": "",
    "tagPath": ""
  },
  "propConfig": {
    "custom.data": {
      "persistent": true
    },
    "custom.data.hum": {
      "binding": {
        "config": {
          "fallbackDelay": 2.5,
          "mode": "indirect",
          "references": {
            "tagPath": "{view.params.tagPath}"
          },
          "tagPath": "{tagPath}/Humidity"
        },
        "type": "tag"
      }
    },
    "custom.data.temp": {
