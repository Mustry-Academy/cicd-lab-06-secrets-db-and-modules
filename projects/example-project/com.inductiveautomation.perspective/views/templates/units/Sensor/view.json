          "references": {
            "tagPath": "{view.params.tagPath}"
          },
          "tagPath": "{tagPath}/Temperature"
        },
        "type": "tag"
      }
    },
    "params.displayName": {
      "paramDirection": "input",
      "persistent": true
    },
